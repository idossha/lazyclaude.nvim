{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(cargo *)",
      "Bash(npm *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash(docker *)",
      "Bash(kubectl *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(curl * | sh)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File written: $CLAUDE_FILE_PATH'"
          }
        ]
      }
    ]
  }
}
